# Copy this file to `.env.local` in the same directory (next to package.json),
# then replace every placeholder with real values. Never commit `.env.local`.
#
#   cp .env.local.example .env.local
#
# Restart `npm run dev` after changing NEXT_PUBLIC_* or Clerk keys.

# ── Clerk (dashboard.clerk.com → your app → API Keys → Development) ──────────
# Use the Development pair for local dev (pk_test_ / sk_test_).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Platform super-admin (Clerk user IDs, comma-separated) — optional locally
PLATFORM_ADMIN_CLERK_IDS=

# Tenant impersonation for training/debug (min 32 random chars). Required to use
# POST /api/admin/impersonate from Platform admin.
IMPERSONATION_SECRET=

# ── Supabase (supabase.com → Project → Settings → API) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ── Anthropic (console.anthropic.com) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (resend.com) ──────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NOTIFICATIONS=
# Used for team invite emails (Team → profile → App Access → Send email) and nudges
RESEND_FROM_TEAM=teams@yourdomain.com
RESEND_FROM_PLATFORM=platform@yourdomain.com
NOTIFY_EMAIL=hello@yourdomain.com
ACCOUNTS_EMAIL=accounts@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ── Twilio (optional for SMS features locally) ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
